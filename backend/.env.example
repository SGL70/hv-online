# Port som backend lyssnar på (valfritt, default 3000)
PORT=3000

# PostgreSQL connection string
DATABASE_URL=postgresql://bataljon:ditt-lösenord@localhost/bataljon

# Hemlig nyckel för JWT-signering — generera med:
# node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=byt-ut-mig-till-lång-slumpmässig-sträng

# Hemlig nyckel för express-session (behövs för BankID-flödet)
SESSION_SECRET=byt-ut-mig-till-lång-slumpmässig-sträng

# Sätt till "production" i produktionsmiljö
NODE_ENV=development

# --- Idura / Criipto BankID ---
# Din Idura-domän (skapas i Idura-dashboarden)
CRIIPTO_DOMAIN=din-domän.test.idura.broker

# OAuth2 client credentials från Idura
CRIIPTO_CLIENT_ID=urn:my:application:identifier:xxxxxx
CRIIPTO_CLIENT_SECRET=din-client-secret

# Callback-URL måste matcha det som är registrerat i Idura
CRIIPTO_CALLBACK_URL=http://localhost:3000/api/auth/bankid/callback

# URL till frontend (för redirect efter inloggning)
FRONTEND_URL=http://localhost:5173
